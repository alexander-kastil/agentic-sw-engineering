### Get exchange rates for EUR (latest)
POST http://localhost:7071/api/GetRates
Content-Type: application/json

{
    "base": "EUR"
}

### Get exchange rates for EUR on specific date
POST http://localhost:7071/api/GetRates
Content-Type: application/json

{
    "base": "EUR",
    "date": "2024-06-15"
}

### Convert 100 EUR to USD (current rate)
POST http://localhost:7071/api/GetConvert
Content-Type: application/json

{
    "from": "EUR",
    "to": "USD",
    "amount": 100
}

### Convert 100 USD to EUR (current rate)
POST http://localhost:7071/api/GetConvert
Content-Type: application/json

{
    "from": "USD",
    "to": "EUR",
    "amount": 100
}

### Convert 50 GBP to JPY (current rate)
POST http://localhost:7071/api/GetConvert
Content-Type: application/json

{
    "from": "GBP",
    "to": "JPY",
    "amount": 50
}

### Convert 1000 EUR to CHF with historical date
POST http://localhost:7071/api/GetConvert
Content-Type: application/json

{
    "from": "EUR",
    "to": "CHF",
    "amount": 1000,
    "date": "2025-06-15"
}
